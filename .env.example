# Core
RASA_PRO_LICENSE=__REMOVED_FROM_GIT_HISTORY__
OPENAI_API_KEY=replace-with-openai-api-key
OPENAI_ORG_ID=

# Admin
ADMIN_EMAIL=admin@alazab.com
ADMIN_PASSWORD=change-this-strong-password
ADMIN_SESSION_SECRET=change-this-long-random-secret
ADMIN_API_KEY=change-this-admin-api-key
ADMIN_SESSION_TTL_SECONDS=604800

# Public URLs and CORS
PUBLIC_BASE_URL=https://bot.alazab.com
ALLOWED_ORIGINS=https://bot.alazab.com,https://www.bot.alazab.com
UPLOADS_PUBLIC_ENABLED=false
MAX_UPLOAD_BYTES=12582912

# Rasa local defaults
RASA_URL=http://127.0.0.1:5005
ACTION_SERVER_URL=http://127.0.0.1:5055/webhook
RASA_REQUEST_TIMEOUT=45
TRAIN_ON_DEPLOY=false

# PostgreSQL
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=alazab_chatbot
DB_USER=alazab_user
DB_PASSWORD=change-this-db-password

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=change-this-redis-password
REDIS_USE_SSL=false

# Meta / WhatsApp / Messenger
FB_VERIFY_TOKEN=change-this-meta-verify-token
FB_APP_ID=
FB_APP_SECRET=
FB_PAGE_ACCESS_TOKEN=
WHATSAPP_API_URL=
WHATSAPP_TOKEN=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=change-this-telegram-webhook-secret
NOTIFY_TG_CHAT_ID=

# Notifications and CRM
NOTIFY_PHONE=
LEAD_RECEIVER_URL=http://127.0.0.1:8000/lead
WEBHOOK_NOTIFY_URL=

# UberFix / maintenance gateway
MAINTENANCE_GATEWAY_URL=
MAINTENANCE_API_KEY=
UBERFIX_API_URL=
UBERFIX_API_KEY=
UBERFIX_TRACK_BASE_URL=https://uberfix.shop/track
LOCAL_BOT_GATEWAY_URL=http://127.0.0.1:8000/uberfix/bot-gateway

# Audio
AUDIO_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
AUDIO_TTS_MODEL=gpt-4o-mini-tts
AUDIO_TTS_VOICE=nova

# Docker Compose
COMPOSE_PROJECT_NAME=alazab-rasa
