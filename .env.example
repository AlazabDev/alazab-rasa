# ══════════════════════════════════════════════════════════════
#  .env.example — AzaBot / Alazab Group
#  انسخ هذا الملف إلى .env واملأ القيم الفعلية
# ══════════════════════════════════════════════════════════════

# ── Rasa Pro License ──────────────────────────────────────────
RASA_PRO_LICENSE=__REMOVED_FROM_GIT_HISTORY__

# ── OpenAI ───────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-replace-with-real-key
OPENAI_ORG_ID=org-replace-with-org-id

# ── Admin Dashboard ───────────────────────────────────────────
ADMIN_EMAIL=manager@alazab.com
ADMIN_PASSWORD=replace-with-strong-password
ADMIN_SESSION_SECRET=replace-with-32-byte-base64-secret

# ── PostgreSQL ────────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=alazab_core
DB_USER=azab_user
DB_PASSWORD=replace-with-db-password

# ── Redis ─────────────────────────────────────────────────────
REDIS_HOST=replace-with-redis-host
REDIS_PORT=6379
REDIS_PASSWORD=replace-with-redis-password
REDIS_USE_SSL=false
REDIS_DB=0
REDIS_LOCK_DB=1
REDIS_KEY_PREFIX=alazab

# ── Public Endpoints ──────────────────────────────────────────
PUBLIC_BASE_URL=https://bot.alazab.com
ALLOWED_ORIGINS=https://alazab.com,https://www.alazab.com,https://bot.alazab.com,https://brand-identity.alazab.com,https://laban-alasfour.alazab.com,https://luxury-finishing.alazab.com,https://uberfix.alazab.com
RASA_URL=http://127.0.0.1:5005
ACTION_SERVER_URL=http://127.0.0.1:5055/webhook

# ── Audio / TTS ───────────────────────────────────────────────
AUDIO_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
AUDIO_TTS_MODEL=gpt-4o-mini-tts
AUDIO_TTS_VOICE=nova

# ── Facebook / Meta ───────────────────────────────────────────
FB_VERIFY_TOKEN=replace-with-verify-token
FB_APP_ID=replace-with-app-id
FB_APP_SECRET=replace-with-app-secret
FB_PAGE_ACCESS_TOKEN=replace-with-page-access-token

# ── WhatsApp ──────────────────────────────────────────────────
WHATSAPP_API_URL=https://graph.facebook.com/v20.0/PHONE_NUMBER_ID/messages
WHATSAPP_TOKEN=replace-with-wa-token
NOTIFY_PHONE=+201000000000
WEBHOOK_NOTIFY_URL=https://chat.alazab.com/webhooks/admin

# ── Telegram ──────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=replace-with-telegram-token
TELEGRAM_WEBHOOK_SECRET=replace-with-webhook-secret
NOTIFY_TG_CHAT_ID=replace-with-chat-id

# ── UberFix Gateway ───────────────────────────────────────────
UBERFIX_API_URL=https://zrrffsjbfkphridqyais.supabase.co/functions/v1/maintenance-gateway
UBERFIX_API_KEY=replace-with-api-key
MAINTENANCE_GETEWAY_URL=https://zrrffsjbfkphridqyais.supabase.co/functions/v1/maintenance-gateway
MAINTENANCE_GETEWAY_API=replace-with-api-key
MAINTENANCE_GETEWAY_URL_TRACK=https://uberfix.shop/track

# ── Security ──────────────────────────────────────────────────
JWT_SECRET=replace-with-jwt-secret-base64
ENCRYPTION_KEY=replace-with-encryption-key-base64
ADMIN_API_KEY=replace-with-admin-api-key-base64

# ── Server ────────────────────────────────────────────────────
NODE_ENV=production
PUBLIC_IP=replace-with-server-ip
LOCAL_IP=replace-with-local-ip
HOSTNAME=azab-server

# ── Deployment ───────────────────────────────────────────────
TRAIN_ON_DEPLOY=false
COMPOSE_PROJECT_NAME=alazab_rasa

# ── Optional: Deepgram / Cartesia ────────────────────────────
DEEPGRAM_API_KEY=replace-if-using-deepgram
CARTESIA_API_KEY=replace-if-using-cartesia
