# Normalize text files
* text=auto

# Shell scripts
*.sh text eol=lf

# Python
*.py text eol=lf

# Web files
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf

# Images / binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.svg text eol=lf
*.ico binary

# Rasa / model binaries
*.tar.gz binary
*.zip binary
*.onnx binary
*.bin binary
*.model binary
