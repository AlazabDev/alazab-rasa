# ══════════════════════════════════════════════════════════════
#  .wslconfig — AzaBot WSL2 Performance Config
#
#  انسخ هذا الملف إلى: C:\Users\<اسمك>\.wslconfig
#  ثم: wsl --shutdown  ثم أعد تشغيل WSL
#
#  ملاحظة: Rasa Pro يحتاج 6–8 GB RAM للعمل بسلاسة
# ══════════════════════════════════════════════════════════════

[wsl2]
memory=8GB
processors=4
swap=4GB
localhostForwarding=true

[experimental]
autoMemoryReclaim=gradual
